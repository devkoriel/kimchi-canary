{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "kimchi-canary",
  "main": "src/index.js",
  "compatibility_date": "2026-04-29",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "kimchi-canary-db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ]
}
